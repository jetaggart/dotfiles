{
  "window.title": "${rootName}${separator}${activeRepositoryBranchName}",
  "window.autoDetectColorScheme": false,
  "editor.cursorSurroundingLines": 9999,
  "search.exclude": {
    "**/__pycache__": true
  },
  "editor.quickSuggestions": {
    "comments": "off",
    "strings": "off",
    "other": "off"
  },
  "editor.suggestOnTriggerCharacters": false,
  "workbench.editor.showTabs": "single",
  "git.openRepositoryInParentFolders": "always",
  "workbench.startupEditor": "none",
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "files.autoSave": "afterDelay",
  "git.autofetch": true,
  "editor.minimap.enabled": false,
  "git.confirmSync": false,
  "go.toolsManagement.autoUpdate": true,
  "workbench.tree.indent": 14,
  "[go]": {
    "editor.insertSpaces": false,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "go.testFlags": [
    "-fullpath",
    "-count=1"
  ],
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.tabSize": 2,
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.formatOnSave": false
  },
  "search.useIgnoreFiles": true,
  "cursor.cpp.disabledLanguages": [
    "plaintext",
    "markdown",
    "scminput"
  ],
  "git.enableSmartCommit": true,
  "terminal.integrated.scrollback": 10000,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "extensions.ignoreRecommendations": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.diffs.useCharacterLevelDiffs": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "cursor.cmdk.autoSelect": false,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "editor.fontSize": 11,
  "editor.fontFamily": "Inconsolata, Menlo, Monaco, 'Courier New', monospace",
  "go.testEnvVars": {
    "SILENCE_SQL_LOGGER": "true"
  },
  "testing.automaticallyOpenTestResults": "neverOpen",
  "go.coverOnTestPackage": false,
  "cursor.general.gitGraphIndexing": "enabled",
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "cursor.composer.textSizeScale": 0.85,
  "cursorpyright.analysis.inlayHints.genericTypes": false,
  "editor.inlayHints.enabled": "off",
  "editor.codeLens": false,
  "editor.minimap.sectionHeaderLetterSpacing": 0.5,
  "window.density.editorTabHeight": "compact",
  "workbench.editor.pinnedTabSizing": "compact",
  "editor.lineHeight": 1.25,
  "git.blame.editorDecoration.enabled": false,
  "claudeCode.preferredLocation": "panel",
  "claudeCode.selectedModel": "default",
  "dotnetAcquisitionExtension.enableTelemetry": false,
  "workbench.colorTheme": "Default Light Modern",
  "githubPullRequests.terminalLinksHandler": "github",
  "diffEditor.renderSideBySide": false
}